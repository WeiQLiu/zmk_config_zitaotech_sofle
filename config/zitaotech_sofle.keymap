#include <dt-bindings/zmk/mouse.h>
#include <dt-bindings/zmk/pointing.h> // 我自己添加的
#include <behaviors.dtsi>
#include <dt-bindings/zmk/backlight.h>
#include <dt-bindings/zmk/bt.h>
#include <dt-bindings/zmk/keys.h>
#include <dt-bindings/zmk/outputs.h>
#include <dt-bindings/zmk/pointing.h>
#include <dt-bindings/zmk/rgb.h>

#define WIN 2
#define FUNC 1
#define BOT bootloader

/ {
    behaviors {
        td0: tap_dance_0 {
            compatible = "zmk,behavior-tap-dance";
            #binding-cells = <0>;
            tapping-term-ms = <400>;
            bindings = <&mkp LCLK>, <&bt BT_CLR>;
        };
    };

    behaviors {
        hm: homerow_mods {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            tapping-term-ms = <500>;
            bindings = <&kp &kp>;
        };
    };

    behaviors {
        sp_sc: behavior_spacescroll {
            compatible = "zmk,behavior-hold-tap";
            #binding-cells = <2>;
            flavor = "tap-preferred";     /* 单击优先 */
            tapping-term-ms = <200>;       /* 长按阈值 */
            bindings = <&none &kp>;        /* hold=none, tap=space */
        };
    };

    behaviors {
        BLE_encoder: BLE_encoder {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&bt BT_NXT>, <&bt BT_PRV>;
        };
    };

    behaviors {
        alt_shift_dance: alt_shift_dance {
            compatible = "zmk,behavior-tap-dance";
            label = "ALT_SHIFT_DANCE";
            #binding-cells = <0>;
            bindings = <&mt LEFT_ALT BACKSPACE>, <&mt LEFT_SHIFT DEL>;
        };
    };

    behaviors {
        hml: homewrow_modes_left {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS_LEFT_HAND";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };
    };

    behaviors {
        hmr: homewrow_mods_right {
            compatible = "zmk,behavior-hold-tap";
            label = "HOMEROW_MODS_RIGHT_HAND";
            bindings = <&kp>, <&kp>;

            #binding-cells = <2>;
            tapping-term-ms = <200>;
            flavor = "tap-preferred";
        };
    };

    behaviors {
        scroll_up_down: behavior_sensor_rotate_mouse_wheel_up_down {
            compatible = "zmk,behavior-sensor-rotate";
            #sensor-binding-cells = <0>;
            bindings = <&msc SCRL_UP>, <&msc SCRL_DOWN>;

            tap-ms = <20>;
    };


    combos {
        compatible = "zmk,combos";

        leftsmallbracket {
            bindings = <&kp LEFT_PARENTHESIS>;
            key-positions = <17 18>;
            layers = <0 2>;
        };

        rightsmallbracket {
            bindings = <&kp RIGHT_PARENTHESIS>;
            key-positions = <21 22>;
            layers = <0 2>;
        };

        esc {
            bindings = <&kp ESC>;
            key-positions = <15 16>;
            layers = <0 2>;
        };

        double-quotation {
            bindings = <&kp DOUBLE_QUOTES>;
            key-positions = <27 28>;
            layers = <0 2>;
        };

        single-quotation {
            bindings = <&kp SQT>;
            key-positions = <37 38>;
            layers = <0 2>;
        };

        enter {
            bindings = <&kp ENTER>;
            key-positions = <41 42>;
            layers = <0 2>;
        };

        slash {
            bindings = <&kp NON_US_BACKSLASH>;
            key-positions = <22 23>;
            layers = <0 2>;
        };

        S_slash {
            bindings = <&kp PIPE>;
            key-positions = <23 24>;
            layers = <0 2>;
        };

        leftsquarebracket {
            bindings = <&kp LEFT_BRACKET>;
            key-positions = <29 30>;
            layers = <0 2>;
        };

        rightsquarebracket {
            bindings = <&kp RIGHT_BRACKET>;
            key-positions = <35 36>;
            layers = <0 2>;
        };

        bigleft {
            bindings = <&kp LEFT_BRACE>;
            key-positions = <43 44>;
            layers = <0 2>;
        };

        bigright {
            bindings = <&kp RIGHT_BRACE>;
            key-positions = <51 52>;
            layers = <0 2>;
        };

        to-windows {
            // bindings = <&to 1>;

            bindings = <&tog 1>;  // 使用宏而不是直接 &to 1
            key-positions = <1 2>;
            layers = <0>;
        };

        to-mac {
            // bindings = <&to 0>;

            bindings = <&mac_pure>;  // 使用宏返回
            key-positions = <0 1>;
            layers = <1>;
        };
    };

    macros {
        // 强制进入 Windows 层并清理其他所有层级

        win_pure: win_pure {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>;
            tap-ms = <10>;
            bindings = <&to 0 &to 1>;
        };

        // 强制回到 Mac 层并清理

        mac_pure: mac_pure {
            compatible = "zmk,behavior-macro";
            #binding-cells = <0>;
            wait-ms = <10>;
            tap-ms = <10>;
            bindings = <&to 0>;
        };
    };

    keymap {
        compatible = "zmk,keymap";

        default_layer {
            // display-name = "QWERTY";

            display-name = "MAC";
            bindings = <
&kp ESC         &kp N1               &kp N2           &kp N3    &kp N4       &kp N5       &kp C_MUTE  &kp C_MUTE  &kp N6     &kp N7     &kp N8  &kp N9            &kp N0                 &kp BSPC
&kp TAB         &kp Q                &kp W            &kp E     &kp R        &kp T        &kp Y       &kp U       &kp I      &kp O      &kp P   &kp SQT
&kp LEFT_SHIFT  &hml LEFT_SHIFT A    &hml LEFT_GUI S  &kp D     &kp F        &kp G        &mkp LCLK   &mkp LCLK   &kp H      &kp J      &kp K   &hmr RIGHT_GUI L  &hmr RIGHT_SHIFT SEMI  &kp ENTER
&kp LCTRL       &hml LEFT_CONTROL Z  &kp X            &kp C     &kp V        &kp B        &kp PG_DN   &kp PG_UP   &mkp LCLK  &mkp RCLK  &kp N   &kp M             &kp COMMA              &kp DOT    &hmr RIGHT_CONTROL FSLH  &kp RSHIFT
&mkp MB2        &mkp MB1             &kp LALT         &kp LGUI  &lt 1 SPACE  &lt 1 SPACE  &kp RGUI    &kp RALT    &mkp MB1   &mkp MB2
            >;

            sensor-bindings =
                <&inc_dec_kp C_VOL_UP C_VOL_DN>,
                <&scroll_up_down>;
                // <&inc_dec_kp PAGE_UP PAGE_DOWN>;
        };

        func_layer {
            display-name = "FUNC";
            bindings = <
&kp GRAVE  &kp F1  &kp F2          &kp F3          &kp F4           &kp F5           &bt BT_CLR  &kp C_MUTE  &kp F6        &kp F7            &kp F8             &kp F9           &kp F10  &kp DEL
&none      &none   &none           &kp UP_ARROW    &none            &out OUT_TOG     &kp F11     &kp F12     &kp UP_ARROW  &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp BACKSLASH
&to 2      &none   &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &none            &mkp RCLK   &mkp RCLK   &none         &kp LEFT_ARROW    &kp DOWN_ARROW     &kp RIGHT_ARROW  &none    &kp SQT
&none      &none   &none           &none           &none            &rgb_ug RGB_TOG  &none       &none       &bl BL_DEC    &bl BL_INC        &none              &none            &none    &kp MINUS  &kp EQUAL  &none
&BOT       &none   &none           &none           &kp LEFT_SHIFT   &kp RIGHT_SHIFT  &none       &none       &none         &BOT
            >;

            sensor-bindings = <&BLE_encoder>, <&inc_dec_kp LG(MINUS) LG(EQUAL)>;
        };

        win_layer {
            // display-name = "RESERVE";

            display-name = "WINDOWS";
            bindings = <
&kp ESC         &kp N1             &kp N2               &kp N3     &kp N4       &kp N5       &kp C_MUTE         &kp C_MUTE  &kp N6     &kp N7     &kp N8  &kp N9                &kp N0                 &kp BSPC
&kp TAB         &kp Q              &kp W                &kp E      &kp R        &kp T        &kp Y              &kp U       &kp I      &kp O      &kp P   &kp BSLH
&kp LEFT_SHIFT  &hml LEFT_SHIFT A  &hml LEFT_CONTROL S  &kp D      &kp F        &kp G        &mkp LCLK          &mkp LCLK   &kp H      &kp J      &kp K   &hmr RIGHT_CONTROL L  &hmr RIGHT_SHIFT SEMI  &kp ENTER
&kp LGUI        &hml LEFT_GUI Z    &kp X                &kp C      &kp V        &kp B        &kp PG_DN          &kp PG_UP   &mkp LCLK  &mkp RCLK  &kp N   &kp M                 &kp COMMA              &kp DOT    &hmr RIGHT_GUI FSLH  &kp RSHIFT
&mkp MB2        &mkp MB1           &kp LALT             &kp LCTRL  &lt 3 SPACE  &lt 3 SPACE  &kp RIGHT_CONTROL  &kp RALT    &mkp MB1   &mkp MB2
            >;

            sensor-bindings =
                <&inc_dec_kp C_VOL_UP C_VOL_DN>,
                <&inc_dec_kp 0x47 0x48>;
                // <&inc_dec_kp PAGE_UP PAGE_DOWN>;
        };

        funcw_layer {
            display-name = "FUNCwin";
            bindings = <
&kp GRAVE  &kp F1  &kp F2          &kp F3          &kp F4           &kp F5           &bt BT_CLR  &kp C_MUTE  &kp F6        &kp F7            &kp F8             &kp F9           &kp F10    &kp DEL
&to 0      &none   &none           &kp UP_ARROW    &none            &out OUT_TOG     &kp F11     &kp F12     &kp UP_ARROW  &kp LEFT_BRACKET  &kp RIGHT_BRACKET  &kp BACKSLASH
&none      &none   &kp LEFT_ARROW  &kp DOWN_ARROW  &kp RIGHT_ARROW  &none            &mkp RCLK   &mkp RCLK   &none         &kp LEFT_ARROW    &kp DOWN_ARROW     &kp RIGHT_ARROW  &kp RIGHT  &kp SQT
&none      &none   &none           &none           &none            &rgb_ug RGB_TOG  &none       &none       &bl BL_DEC    &bl BL_INC        &none              &none            &none      &kp MINUS  &kp EQUAL  &none
&BOT       &none   &none           &none           &kp LEFT_SHIFT   &kp RIGHT_SHIFT  &none       &none       &none         &BOT
            >;

            sensor-bindings = <&BLE_encoder>, <&inc_dec_kp LEFT RIGHT_ARROW>;
        };
    };
};
